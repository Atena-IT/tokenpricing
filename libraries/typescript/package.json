{
  "name": "tokenpricing",
  "version": "0.1.0",
  "description": "API pricing math for 1k+ AI models with multi-currency support",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "llm",
    "pricing",
    "token",
    "cost",
    "openai",
    "anthropic",
    "ai"
  ],
  "author": "Federico Minutoli",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Atena-IT/tokenpricing.git",
    "directory": "libraries/typescript"
  },
  "homepage": "https://github.com/Atena-IT/tokenpricing/tree/main/libraries/typescript",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "fuse.js": "^7.3.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@types/node": "^25.5.2",
    "@vitest/coverage-v8": "^3.2.4",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^3.2.4"
  }
}
